# Copie este arquivo para .env e preencha os valores reais
# cp .env.example .env

# Porta onde o backend roda
PORT=3333

# Origem permitida pelo CORS (URL do frontend)
ALLOWED_ORIGIN=http://localhost:5173

# Segredo para assinar tokens JWT - gere um valor aleatório forte:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
